{
  "name": "automator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,worker -c cyan,magenta \"next dev\" \"npm --prefix worker run dev\"",
    "dev:web": "next dev",
    "dev:worker": "npm --prefix worker run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:init": "node --env-file=.env scripts/init-db.mjs",
    "worker:install": "npm --prefix worker install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "^15.5.19",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
